{
  "name": "@radum/eslint-config",
  "type": "module",
  "version": "10.1.0",
  "packageManager": "pnpm@10.17.0",
  "description": "@radum ESLint Shareable Config",
  "author": "Radu Micu",
  "license": "MIT",
  "funding": "https://github.com/sponsors/radum",
  "homepage": "https://github.com/radum/eslint-config",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/radum/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/radum/eslint-config/issues"
  },
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "eslint-config": "bin/index.js"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md",
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm gen && tsdown --clean --dts",
    "stub": "tsdown",
    "dev": "npx @eslint/config-inspector --config eslint.config.ts",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build",
    "watch": "tsdown --watch",
    "lint": "eslint",
    "gen": "tsx scripts/typegen.ts && tsx scripts/versiongen.ts",
    "prepack": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@next/eslint-plugin-next": "^15.5.3",
    "@prettier/plugin-xml": "^3.4.2",
    "@unocss/eslint-plugin": ">=66.5.1",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.36.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": ">=1.0.2",
    "eslint-plugin-jsx-a11y": ">=6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-svelte": ">=3.12.3",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-slidev": "^1.0.5",
    "svelte-eslint-parser": ">=1.3.2"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "@next/eslint-plugin-next": {
      "optional": true
    },
    "@prettier/plugin-xml": {
      "optional": true
    },
    "@unocss/eslint-plugin": {
      "optional": true
    },
    "astro-eslint-parser": {
      "optional": true
    },
    "eslint-plugin-astro": {
      "optional": true
    },
    "eslint-plugin-format": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    },
    "eslint-plugin-solid": {
      "optional": true
    },
    "eslint-plugin-svelte": {
      "optional": true
    },
    "eslint-plugin-vuejs-accessibility": {
      "optional": true
    },
    "prettier-plugin-astro": {
      "optional": true
    },
    "prettier-plugin-slidev": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@clack/prompts": "^0.11.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.5.0",
    "@eslint/markdown": "^7.2.0",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "@vitest/eslint-plugin": "^1.3.12",
    "ansis": "^4.1.0",
    "cac": "^6.7.14",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-flat-config-utils": "^2.1.4",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.1.1",
    "eslint-plugin-command": "^3.3.1",
    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-import-lite": "^0.3.0",
    "eslint-plugin-jsdoc": "^59.0.2",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-pnpm": "^1.1.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-toml": "^0.12.0",
    "eslint-plugin-unicorn": "^61.0.2",
    "eslint-plugin-unused-imports": "^4.2.0",
    "eslint-plugin-vue": "^10.4.0",
    "eslint-plugin-yml": "^1.18.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^16.4.0",
    "jsonc-eslint-parser": "^2.4.0",
    "local-pkg": "^1.1.2",
    "parse-gitignore": "^2.0.0",
    "toml-eslint-parser": "^0.10.0",
    "vue-eslint-parser": "^10.2.0",
    "yaml-eslint-parser": "^1.3.0"
  },
  "devDependencies": {
    "@auto-it/all-contributors": "^11.3.0",
    "@auto-it/first-time-contributor": "^11.3.0",
    "@auto-it/npm": "^11.3.0",
    "@auto-it/released": "^11.3.0",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@eslint/config-inspector": "^1.3.0",
    "@next/eslint-plugin-next": "^15.5.3",
    "@prettier/plugin-xml": "^3.4.2",
    "@radum/eslint-config": "workspace:*",
    "@types/eslint-plugin-jsx-a11y": ">=6.10.0",
    "@types/node": "^24.5.2",
    "@unocss/eslint-plugin": "^66.5.1",
    "astro-eslint-parser": "^1.2.2",
    "auto": "^11.3.0",
    "eslint": "^9.36.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-jsx-a11y": ">=6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-svelte": "^3.12.3",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "eslint-typegen": "^2.3.0",
    "execa": "^9.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.6",
    "pnpm-workspace-yaml": "^1.1.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-slidev": "^1.0.5",
    "svelte": "^5.39.2",
    "svelte-eslint-parser": "^1.3.22",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.14.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vue": "^3.5.21"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
